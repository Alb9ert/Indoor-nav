generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
  foo String
}

model FloorPlan {
  id                   Int     @id @default(autoincrement())
  floor                Int     @unique
  imageUrl             String
  aspectRatio          Float
  calibrationScale     Float   @default(1.0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}