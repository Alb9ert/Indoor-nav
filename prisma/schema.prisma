generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  username        String?   @unique
  displayUsername String?
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Section {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rooms     Room[]
}

model Room {
  id            String    @id
  roomNumber    String
  displayName   String
  isActivated   Boolean   @default(true)
  semanticNames String[]
  type          RoomType

  /// PostGIS geometry columns (SRID 0 - local Cartesian meters in the floor frame)
  pointZ        Unsupported("geometry(PointZ, 0)")?
  polygon       Unsupported("geometry(Polygon, 0)")?
  multiPolygon  Unsupported("geometry(MultiPolygon, 0)")?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sectionId     String?
  section       Section?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  /// Floor this room lives on. Coordinates are in this floor's local frame.
  floor         Int
  floorPlan     FloorPlan @relation(fields: [floor], references: [floor], onDelete: Cascade)

  /// A room can have many nodes.
  /// A node may optionally belong to a room.
  nodes         Node[]

  @@index([sectionId])
  @@index([type])
  @@index([isActivated])
  @@index([floor])
}

model Node {
  id            String    @id @default(cuid())
  x             Float
  y             Float
  z             Float
  type          NodeType
  isActivated   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  roomId        String?
  room          Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)

  /// Floor this node lives on. Coordinates are in this floor's local frame.
  floor         Int
  floorPlan     FloorPlan @relation(fields: [floor], references: [floor], onDelete: Cascade)

  edgesFrom     Edge[]    @relation("EdgeFromNode")
  edgesTo       Edge[]    @relation("EdgeToNode")

  @@index([roomId])
  @@index([type])
  @@index([isActivated])
  @@index([x, y, z])
  @@index([floor])
}

model Edge {
  id          String   @id @default(cuid())
  distance    Float
  doors       Boolean  @default(false)
  stairs      Boolean  @default(false)
  elevators   Boolean  @default(false)
  isActivated Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Undirected edge stored as two node references.
  /// Normalize ordering in backend logic before insert.
  fromNodeId  String
  toNodeId    String

  fromNode    Node     @relation("EdgeFromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode      Node     @relation("EdgeToNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@index([isActivated])
}

enum NodeType {
  DEFAULT
}

enum RoomType {
  DEFAULT
  CLASSROOM
  MEETING_ROOM
  OFFICE
  STUDY_SPACE
  AUDITORIUM
  LIBRARY
  FOOD_DRINK
  FACILITY
}

model FloorPlan {
  floor                Int     @id @unique
  path                 String
  calibrationScale     Float   @default(1.0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  rooms                Room[]
  nodes                Node[]
}
